{
  "name": "css-ast-viewer",
  "version": "1.0.0",
  "description": "Herramienta visual para parsear CSS y explorar su AST como arbol interactivo",
  "main": "server.ts",
  "scripts": {
    "dev": "run-p server dev:vite",
    "dev:vite": "vite",
    "server": "tsx server.ts",
    "parse": "tsx parse-css.ts",
    "test": "tsx --test tests/node-to-json.test.js && npx playwright test",
    "test:unit": "tsx --test tests/node-to-json.test.js",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "css",
    "ast",
    "parser",
    "postcss",
    "viewer"
  ],
  "author": "Juan Carlos Galindo Navarro",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "express": "^5.2.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "npm-run-all2": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
